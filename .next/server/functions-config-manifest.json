{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/((?!_next\\/static|_next\\/image|favicon.ico|api\\/|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$|_vercel\\/|ingest\\/|ph-proxy\\/|array\\/|mintlify-assets\\/|_mintlify\\/).*))(\\.json)?[\\/#\\?]?$",
          "originalSource": "/((?!_next/static|_next/image|favicon.ico|api/|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$|_vercel/|ingest/|ph-proxy/|array/|mintlify-assets/|_mintlify/).*)"
        }
      ]
    },
    "/api/health": {
      "maxDuration": 10
    },
    "/dashboard/inspect/sandbox/[sandboxId]": {
      "maxDuration": 60
    }
  }
}