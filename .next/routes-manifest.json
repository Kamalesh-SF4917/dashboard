      "source": "/docs/api/cli",
      "destination": "/auth/cli",
      "statusCode": 308,
      "regex": "^(?!/_next)/docs/api/cli(?:/)?$"
    },
    {
      "source": "/auth/sign-in",
      "destination": "/sign-in",
      "statusCode": 308,
      "regex": "^(?!/_next)/auth/sign-in(?:/)?$"
