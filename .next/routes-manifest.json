      "regex": "^(?!/_next)/auth/sign-up(?:/)?$"
    },
    {
      "source": "/ai-agents/:path*",
      "destination": "/",
      "statusCode": 308,
      "regex": "^(?!/_next)/ai-agents(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    }
  ],
